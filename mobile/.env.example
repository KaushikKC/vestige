# Privy (from dashboard.privy.io). Only EXPO_PUBLIC_* vars are available in the app.
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Solana RPC URL (optional; defaults to devnet if unset)
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Supabase (from app.supabase.com → Project Settings → API)
# Project URL and anon public key; required for comments and realtime.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
